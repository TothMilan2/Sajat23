<Window x:Class="Sajat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sajat"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="Panel">
        <ListView>
            <ListViewItem Width="300" x:Name="felhasznaloMenu" Margin="0,30,0,0" Content="Felhasználók" MouseDoubleClick="felhasznaloMenu_MouseDoubleClick" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="Black" Padding="4">

            </ListViewItem>
            <ListViewItem Width="300" x:Name="vasarloMenu" Margin="0,30,0,0" Content="Vásárlók" MouseDoubleClick="vasarloMenu_MouseDoubleClick" BorderThickness="1" BorderBrush="Black" Padding="4">

            </ListViewItem>
            <ListViewItem Width="300" x:Name="termekMenu" Margin="0,30,0,0" Content="Termékek" BorderThickness="1" BorderBrush="Black" Padding="4" MouseDoubleClick="termekMenu_MouseDoubleClick">

            </ListViewItem>
        </ListView>
        

    </Grid>
</Window>
