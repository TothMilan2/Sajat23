<Window x:Class="Sajat.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sajat.Views"
        mc:Ignorable="d"
       
        Background="Black"
        Foreground="White"
        Title="Login" Height="450" Width="400">
    <Grid>
        <StackPanel>
            <Label Content="Bejelentkezés"  Foreground="White" Margin="10" HorizontalAlignment="Center" FontSize="23" FontWeight="Bold"  FontFamily="Bahnschrift"/>
            <TextBlock  Foreground="White" Margin="10" FontSize="14">Felhasználónév</TextBlock>
            <TextBox x:Name="felhasznaloNevTextBox"  Margin="10" Height="30" FontSize="16" FontFamily="Bahnschrift" />
            <TextBlock  Foreground="White" Margin="10" FontSize="14">Jelszó</TextBlock>
            <PasswordBox x:Name="jelszoBox" Margin="10" Height="30" FontSize="16" FontFamily="Bahnschrift" />
            <Button x:Name="loginBtn" Content="Bejelentkezés" Margin="50" Height="40" Background="Beige" Foreground="Black" FontSize="16" FontFamily="Bahnschrift" Click="loginBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
