<UserControl x:Class="Sajat.Views.UserControl_Felhasznalok"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sajat.Views"
             mc:Ignorable="d" 
             
             d:DesignHeight="550" d:DesignWidth="800">
    <StackPanel Orientation="Horizontal">
        <DataGrid
        x:Name="datagridFelhasznalok"
        
        Width="470"
        Height="500"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        IsReadOnly="True"
        SelectionChanged="datagridFelhasznalok_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding id}" Header="ID" />
                <DataGridTextColumn Binding="{Binding FelhasznaloNev}" Header="Felhasználó név" />
                <DataGridTextColumn Binding="{Binding TeljesNev}" Header="Teljes név" />
                <DataGridTextColumn Binding="{Binding Jelszo}" Header="Jelszó" />
                <DataGridTextColumn Binding="{Binding Szerepkor}" Header="Szerepkör Id" />
                <DataGridTextColumn Binding="{Binding SzerepkorNev}" Header="Szerepkör név " />
                <DataGridTextColumn Binding="{Binding }" Header="Körözik-e" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Width="250" Height="400"  Margin="50" Background="Black" >
            <StackPanel Width="200" Margin="20"  >
                <TextBlock Text="Felhasználó név" Foreground="White" />
                <TextBox x:Name="felhasznaloNevTextBox" />
                <TextBlock Text="Teljes név" Foreground="White" />
                <TextBox x:Name="teljesNevTextBox" />
                <TextBlock Text="Jelszo"  Foreground="White"/>
                <PasswordBox x:Name="jelszoBox" />
                <TextBlock Text="Körözik-e" Foreground="White"></TextBlock>
                <CheckBox x:Name="korozik"></CheckBox>
                <TextBlock Text="Szerepkör" Foreground="White" />
                <ComboBox x:Name="szerepkor" />
            </StackPanel>
            <StackPanel Width="150" >
                <Button
                x:Name="mentesBtn"
                Width="100"
                Margin="10,10,0,0"
                Background="Beige"
                Click="mentesBtn_Click"
                Content="Mentés"
                Foreground="Black" 
                    BorderThickness="0"/>
                <Button
                x:Name="torlesBtn"
                Width="100"
                Margin="10,10,0,0"
                Background="Red"
                Click="torlesBtn_Click"
                Content="Törlés"
                Foreground="White" 
                    BorderThickness="0"/>
                <Button
                x:Name="modBtn"
                Width="100"
                Margin="10,10,0,0"
                Background="Yellow"
                Click="modBtn_Click"
                Content="Módosítás"
                Foreground="Black" 
                    BorderThickness="0"/>
            </StackPanel>
        </WrapPanel>

    </StackPanel>
</UserControl>
